# Idea可行性验证工具 - 环境变量配置模板
# 复制此文件为 .env 并填写实际值

# DeepSeek API配置
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 数据库配置
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/whetherwecando

# MediaCrawler配置
COOKIE_PATH=./cache/cookies
CACHE_PATH=./cache

# 服务配置
API_HOST=0.0.0.0
API_PORT=8000

# 日志配置
LOG_LEVEL=INFO
